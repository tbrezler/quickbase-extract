# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# ============================================================
# All Files
# ============================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================
# Python Files
# ============================================================
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# ============================================================
# JSON
# ============================================================
[*.json]
indent_style = space
indent_size = 2

# ============================================================
# YAML
# ============================================================
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ============================================================
# Markdown
# ============================================================
[*.md]
trim_trailing_whitespace = false
